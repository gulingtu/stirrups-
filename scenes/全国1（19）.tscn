text = "已知函数 f(x) 的定义域为 R，且当 x < 0 时，f(x) = 2^x。对于任意 x₀ ∈ R，定义集合 D(x₀) = {d ∈ R | f(x₀ + d) > f(x₀)}。"
autowrap_mode = 2

[node name="Question1" type="Label" parent="UI"]
layout_mode = 0
offset_left = 10.0
offset_top = 120.0
offset_right = 450.0
offset_bottom = 145.0
text = "(1) 若 f(x) = 1 - x (x ≥ 0)，求集合 D(-1)"

[node name="Question2" type="Label" parent="UI"]
layout_mode = 0
offset_left = 10.0
offset_top = 155.0
offset_right = 450.0
offset_bottom = 195.0
text = "(2) 若 f(x) 为奇函数，且对于任意满足 x₁x₂ ≠ 0 的 x₁, x₂，f(x₁) ≤ f(x₂)，证明：D(x₁) ⊇ D(x₂)"
autowrap_mode = 2

[node name="Question3" type="Label" parent="UI"]
layout_mode = 0
