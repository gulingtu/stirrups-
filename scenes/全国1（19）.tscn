offset_top = 205.0
offset_right = 450.0
offset_bottom = 270.0
text = "(3) 若 f(x) 满足：(a) 当 f(x₁) ≤ f(x₂) 时，D(x₁) ⊇ D(x₂); (b) 当 0 < x < 1 时，f(x) < f(0)。证明：(i) f(0) ≥ 1; (ii) f(x) 在 (0, +∞) 上单调递增"
autowrap_mode = 2

